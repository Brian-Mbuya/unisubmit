# Local PostgreSQL defaults
PGHOST=localhost
PGPORT=5432
PGDATABASE=unisubmit
PGUSER=unisubmit
PGPASSWORD=unisubmit

# Server
PORT=8080
APP_UPLOAD_DIR=uploads
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000

# Managed PostgreSQL providers such as Supabase may use a full JDBC URL.
# Example:
# JDBC_DATABASE_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
