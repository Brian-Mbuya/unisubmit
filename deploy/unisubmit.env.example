# ---------------------------------------------------------------------------
# UniSubmit server environment  ->  installed to /etc/unisubmit.env (chmod 600)
# Values are read by the Spring Boot app (see src/main/resources/application.yml)
# and by the systemd unit. NEVER commit the real file — only this .example.
# ---------------------------------------------------------------------------

# --- Supabase Postgres (SESSION pooler, port 5432) --------------------------
# Get these from: Supabase Dashboard -> your project -> "Connect" button ->
# "Session pooler" tab. Use the SESSION pooler (5432), NOT the Transaction
# pooler (6543): Flyway migrations need advisory locks / prepared statements.
#
# The host/user below are pre-filled for project "unisubmit" (region eu-west-1).
# Confirm them against the dialog, then paste your database password.
#
# pgvector NOTE: for semantic search the `embedding` column is migrated to vector(1536)
# and the app writes it as text — Postgres needs the driver to leave the type unspecified.
# The URL ALREADY has `?sslmode=require`, so APPEND with an ampersand (a second `?` = boot
# failure): ...postgres?sslmode=require&stringtype=unspecified
JDBC_DATABASE_URL=jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
PGUSER=postgres.pzeerzaglvjzefbkadcf
PGPASSWORD=PASTE_YOUR_SUPABASE_DB_PASSWORD_HERE

# --- App --------------------------------------------------------------------
PORT=8080
APP_UPLOAD_DIR=/opt/unisubmit/uploads
SERVER_FORWARD_HEADERS_STRATEGY=framework
JAVA_OPTS=-Xmx768m

# --- Timezone ---------------------------------------------------------------
# Deadlines enforce on the JVM's wall-clock. Pin it to Nairobi (EAT, UTC+3) so a
# deadline typed as 23:59 fires at 23:59 local. Set BOTH (belt and braces): TZ
# alone depends on the distro's tzdata; -Duser.timezone forces the JVM default.
# The Railway Dockerfile already bakes both in — this documents them for the
# Oracle/systemd path. WARNING: flipping the zone shifts the DISPLAYED time of
# EXISTING naive timestamps (+3h) — re-check any live deadline after the first
# deploy with this change.
TZ=Africa/Nairobi
# JAVA_OPTS already carries the heap flags above; if you launch java directly,
# also pass -Duser.timezone=Africa/Nairobi.

# Connection pool — keep modest for Supabase free tier + pooler.
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000

# --- Optional features (OFF for a lean launch; enable later if wanted) -------
# GROBID_ENABLED=false
# SPECTER_ENABLED=false
# OCR_ENABLED=false
# OPENAI_API_KEY=sk-...            # chat/analysis (OpenRouter or OpenAI)
# OPENAI_MODEL=openai/gpt-4o-mini
# --- Semantic search (needs a SEPARATE embeddings key — OpenRouter has none) --
# 1) run the pgvector SQL in Supabase (see RAILWAY.md), 2) add &stringtype=unspecified to
# JDBC_DATABASE_URL (above), 3) set EMBEDDINGS_API_KEY, 4) run the backfill from Admin →
# Evaluation, 5) create the HNSW index, 6) then flip SEARCH_SEMANTIC_ENABLED=true.
# EMBEDDINGS_API_KEY=sk-...        # OpenAI key for text-embedding-3-small (1536-dim)
# EMBEDDINGS_URL=https://api.openai.com/v1/embeddings
# SEARCH_SEMANTIC_ENABLED=false
