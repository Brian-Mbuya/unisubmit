# ---------------------------------------------------------------------------
# UniSubmit server environment  ->  installed to /etc/unisubmit.env (chmod 600)
# Values are read by the Spring Boot app (see src/main/resources/application.yml)
# and by the systemd unit. NEVER commit the real file — only this .example.
# ---------------------------------------------------------------------------

# --- Supabase Postgres (SESSION pooler, port 5432) --------------------------
# Get these from: Supabase Dashboard -> your project -> "Connect" button ->
# "Session pooler" tab. Use the SESSION pooler (5432), NOT the Transaction
# pooler (6543): Flyway migrations need advisory locks / prepared statements.
#
# The host/user below are pre-filled for project "unisubmit" (region eu-west-1).
# Confirm them against the dialog, then paste your database password.
JDBC_DATABASE_URL=jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
PGUSER=postgres.pzeerzaglvjzefbkadcf
PGPASSWORD=PASTE_YOUR_SUPABASE_DB_PASSWORD_HERE

# --- App --------------------------------------------------------------------
PORT=8080
APP_UPLOAD_DIR=/opt/unisubmit/uploads
SERVER_FORWARD_HEADERS_STRATEGY=framework
JAVA_OPTS=-Xmx768m

# Connection pool — keep modest for Supabase free tier + pooler.
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000

# --- Optional features (OFF for a lean launch; enable later if wanted) -------
# GROBID_ENABLED=false
# SPECTER_ENABLED=false
# OCR_ENABLED=false
# SEARCH_SEMANTIC_ENABLED=false
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=openai/gpt-4o-mini
